{
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@eslint/js": "^10.0.1",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.33"
  },
  "scripts": {
    "docs:dev:site": "vitepress dev docs --host 127.0.0.1 --port 5173 --strictPort",
    "editor:dev": "npm --prefix editor run dev -- --host 127.0.0.1 --port 5174 --strictPort",
    "docs:dev": "concurrently -n DOCS,EDITOR -c yellow,cyan \"npm run docs:dev:site\" \"npm run editor:dev\"",
    "docs:build": "npm run editor:bundle && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "editor:build": "npm --prefix editor run build",
    "editor:publish": "node scripts/publish-editor.mjs",
    "editor:bundle": "npm run editor:build && npm run editor:publish",
    "editor:clean": "node scripts/clean-editor-public.mjs",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/nprogress": "^0.2.3",
    "@vueuse/core": "^14.3.0",
    "globals": "^17.6.0",
    "nprogress": "^0.2.0",
    "tailwindcss": "^4.2.4"
  }
}
