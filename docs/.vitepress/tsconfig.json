{
  "compilerOptions": {
    "strict": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext",
    "types": ["vite/client"]
  },
  "include": ["./**/*.mts", "./**/*.ts"],
  "exclude": ["dist", "cache"]
}
